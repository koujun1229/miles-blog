---
/**
 * NoteLatestPosts.astro
 * note.com の最新記事をRSSから取得して表示するコンポーネント。
 *
 * 使用例:
 *   <NoteLatestPosts accountId="your-note-id" />
 *
 * ビルド時にSSG（静的生成）でフェッチするため、
 * リアルタイム更新が必要な場合はCloudflare Pagesの
 * デプロイフックと組み合わせてください。
 */
import { fetchNoteRSS } from '@/utils/rss';

interface Props {
  accountId: string;  // note.com のアカウントID
  limit?: number;
}

const { accountId, limit = 5 } = Astro.props;
const posts = await fetchNoteRSS(accountId, limit);

const dateFormatter = new Intl.DateTimeFormat('ja-JP', { month: 'short', day: 'numeric' });
---

<aside class="rounded-2xl border border-gray-100 dark:border-gray-800 overflow-hidden">
  <div class="flex items-center justify-between px-4 py-3 bg-gray-50 dark:bg-brand-navy-light border-b border-gray-100 dark:border-gray-800">
    <div class="flex items-center gap-2">
      <!-- note.com ロゴ的なアイコン -->
      <svg class="w-4 h-4 text-[#41C9B4]" viewBox="0 0 24 24" fill="currentColor">
        <path d="M19 3H5C3.895 3 3 3.895 3 5v14c0 1.105.895 2 2 2h14c1.105 0 2-.895 2-2V5c0-1.105-.895-2-2-2zm-7 14H8v-2h4v2zm4-4H8v-2h8v2zm0-4H8V7h8v2z"/>
      </svg>
      <span class="text-sm font-semibold text-gray-900 dark:text-gray-100">noteの最新記事</span>
    </div>
    <a
      href={`https://note.com/${accountId}`}
      target="_blank"
      rel="noopener noreferrer"
      class="text-xs text-gray-400 hover:text-brand-gold transition-colors"
    >
      すべて見る →
    </a>
  </div>

  {posts.length === 0 && (
    <div class="px-4 py-6 text-center text-sm text-gray-400">
      現在取得できません
    </div>
  )}

  <ul class="divide-y divide-gray-50 dark:divide-gray-800">
    {posts.map((post) => (
      <li>
        <a
          href={post.link}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-start gap-3 px-4 py-3 hover:bg-gray-50 dark:hover:bg-brand-navy-light transition-colors group"
        >
          {post.thumbnail && (
            <img
              src={post.thumbnail}
              alt=""
              class="w-12 h-12 rounded-lg object-cover flex-shrink-0 mt-0.5"
              loading="lazy"
              decoding="async"
            />
          )}
          <div class="min-w-0">
            <p class="text-sm font-medium text-gray-900 dark:text-gray-100 line-clamp-2 group-hover:text-brand-gold dark:group-hover:text-brand-gold-light transition-colors leading-snug">
              {post.title}
            </p>
            <time class="text-xs text-gray-400 mt-1 block" datetime={post.pubDate.toISOString()}>
              {dateFormatter.format(post.pubDate)}
            </time>
          </div>
        </a>
      </li>
    ))}
  </ul>
</aside>
