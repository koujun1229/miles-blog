---
const navLinks = [
  { href: '/blog/cards',    label: 'カード' },
  { href: '/blog/hotels',   label: 'ホテル' },
  { href: '/blog/strategy', label: '戦略' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/90 dark:bg-brand-navy/90 backdrop-blur-md border-b border-gray-100 dark:border-gray-800">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-14">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group" aria-label="トップページへ">
        <span class="text-brand-gold text-xl">✦</span>
        <span class="font-bold text-sm sm:text-base leading-tight text-gray-900 dark:text-gray-50 group-hover:text-brand-gold dark:group-hover:text-brand-gold-light transition-colors">
          限界旅行好きの<br class="sm:hidden" />マイル活用法
        </span>
      </a>

      <!-- Nav + Dark mode -->
      <div class="flex items-center gap-1 sm:gap-2">
        <nav class="flex items-center gap-1">
          {navLinks.map(({ href, label }) => (
            <a
              href={href}
              class:list={[
                'px-3 py-1.5 rounded-lg text-sm font-medium transition-colors',
                currentPath.startsWith(href)
                  ? 'bg-brand-gold/10 text-brand-gold dark:text-brand-gold-light'
                  : 'text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 hover:bg-gray-100 dark:hover:bg-gray-800',
              ]}
            >
              {label}
            </a>
          ))}
        </nav>

        <!-- Dark mode toggle -->
        <button
          id="theme-toggle"
          aria-label="ダークモード切替"
          class="p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
        >
          <svg id="icon-sun" class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <svg id="icon-moon" class="w-4 h-4 block dark:hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('theme-toggle');
  btn?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>
