---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="ページが見つかりません">
  <div class="flex flex-col items-center justify-center py-24 text-center">
    <span class="text-brand-gold text-6xl mb-6">✦</span>
    <h1 class="text-4xl font-bold mb-3 text-gray-900 dark:text-gray-50">404</h1>
    <p class="text-gray-500 dark:text-gray-400 mb-8">ページが見つかりませんでした。</p>
    <a
      href="/"
      class="px-6 py-3 rounded-xl bg-brand-gold text-white font-semibold hover:bg-brand-gold-light transition-colors"
    >
      トップページへ戻る
    </a>
  </div>
</BaseLayout>
